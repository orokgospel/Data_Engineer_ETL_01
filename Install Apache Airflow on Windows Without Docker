# Update versions here as per the instructions above
AIRFLOW_VERSION=3.1.8
PYTHON_VERSION=3.12
#IN your ubuntu terminal
#1. Run these commands in your ubuntun terminal each
AIRFLOW_VERSION=3.1.8
PYTHON_VERSION=3.12

#2 Update the packages using sudo apt update command below and please enter password if prompted
sudo apt update

#3 Install the required Python version along with necessary packages
sudo apt install -y python${PYTHON_VERSION} python${PYTHON_VERSION}-venv python${PYTHON_VERSION}-dev python3-pip build-essential

#4 Create a virtual environment for Airflow and activate it
mkdir -p ~/venvs
python${PYTHON_VERSION} -m venv ~/venvs/airflow_${AIRFLOW_VERSION}
source ~/venvs/airflow_${AIRFLOW_VERSION}/bin/activate

#4 Upgrade pip to the latest version
pip install --upgrade pip

#5 Define the constraint-file URL
CONSTRAINT_URL="https://raw.githubusercontent.com/apache/airflow/constraints-${AIRFLOW_VERSION}/constraints-${PYTHON_VERSION}.txt"

#6 Install Apache Airflow with the specified version and constraints (dependency versions)
pip install "apache-airflow==${AIRFLOW_VERSION}" --constraint "$CONSTRAINT_URL"


#7 Next is to run or iniotiate the airflow intalled and you can always run this  anytime you want to execute or inititae airflow
# this part can be saved inhome directory and be rum in one go and make sure to keep terminal running do not close terminal inititated while running airflow.
#!/bin/bash
set -e
# Before running, update the AIRFLOW_VERSION below as needed:
AIRFLOW_VERSION=3.1.8
# Activate the virtual environment:
source ~/venvs/airflow_${AIRFLOW_VERSION}/bin/activate
# Launch Airflow and its components:
airflow standalone

#8 login via web page and login with admin as user and password generated by airflow in airflow log:
http://localhost:8080/
